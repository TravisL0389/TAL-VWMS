# =============================================================================
# VWMS Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
#
# The app works fully without any API key — Smart Pull falls back to a
# deterministic nearest-neighbour route planner. If you provide a Gemini key
# below, Smart Pull will instead use Google's gemini-2.5-flash to plan routes
# and the Dashboard will surface AI-driven inventory insights.
# =============================================================================

# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
